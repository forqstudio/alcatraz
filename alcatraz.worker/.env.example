NATS_URL=nats://localhost:4222
NATS_SUBJECT=vm.spawn
NATS_QUEUE_GROUP=worker-vm-spawn
NATS_READY_SUBJECT=vm.ready
NATS_DESTROYED_SUBJECT=vm.destroyed
NATS_DESTROY_SUBJECT=vm.destroy
NATS_DESTROY_QUEUE_GROUP=worker-vm-destroy
SEQ_URL=http://localhost:5341
SEQ_API_KEY=
APPLICATION=alcatraz-worker
ENVIRONMENT=development
WORKER_CA_PUBKEY_PATH=/run/alcatraz-ca/alcatraz_ca.pub

# VM artifact paths. Defaults derive from the executable's location
# (<repo>/alcatraz.worker/bin/alcatraz-worker → <repo>/alcatraz.core/...), so
# you only need to set these if alcatraz.core/ lives somewhere unusual or you
# moved the binary to /usr/local/bin. The worker fails fast at startup if a
# resolved path doesn't exist, so a typo crashes on boot rather than 30s into
# a customer's spawn.
# WORKER_FIRECRACKER_BIN=/abs/path/to/alcatraz.core/bin/firecracker-v1.15.1
# WORKER_KERNEL_PATH=/abs/path/to/alcatraz.core/linux-amazon/vmlinux
# WORKER_ROOTFS_PATH=/abs/path/to/alcatraz.core/rootfs
# WORKER_AGENTFS_DATA=/abs/path/to/alcatraz.core/.agentfs
