{
  "ConnectionStrings": {
    "Database": "Host=alcatraz-db;Port=5432;Database=alcatraz;Username=postgres;Password=postgres;",
    "Cache": "alcatraz-redis:6379"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://alcatraz-seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Audience": "account",
    "ValidIssuer": "http://alcatraz-idp:8080/realms/alcatraz",
    "MetadataUrl": "http://alcatraz-idp:8080/realms/alcatraz/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "Keycloak": {
    "BaseUrl": "http://alcatraz-idp:8080",
    "AdminUrl": "http://alcatraz-idp:8080/admin/realms/alcatraz/",
    "TokenUrl": "http://alcatraz-idp:8080/realms/alcatraz/protocol/openid-connect/token",
    "DeviceAuthorizationUrl": "http://alcatraz-idp:8080/realms/alcatraz/protocol/openid-connect/auth/device",
    "AdminClientId": "alcatraz-admin-client",
    "AdminClientSecret": "UZDmbNxWmV4TlpaCRcju6pMRsyuV3er1",
    "AuthClientId": "alcatraz-auth-client",
    "AuthClientSecret": "3E3yvXaYppoYBF3Ir6DgtEzADKKzSurZ"
  },
  "Outbox": {
    "IntervalInSeconds": 10,
    "BatchSize": 10
  },
  "Nats": {
    "Url": "nats://alcatraz-nats:4222",
    "SpawnSubject": "vm.spawn",
    "DestroySubject": "vm.destroy"
  },
  "Ssh": {
    "CA": {
      "PrivateKeyPath": "/run/alcatraz-ca/alcatraz_ca",
      "DefaultTtlHours": 24,
      "SshKeygenPath": "ssh-keygen"
    }
  },
  "Gateway": {
    "Host": "ssh.alcatraz.io",
    "Port": 443
  }
}
